# Required — your Anthropic API key. Get one at https://console.anthropic.com
# Without it, every agent run fails with a clear "Authentication failed" banner.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — override the dev / container port (default 7340).
# Both `npm run dev` and the production server honour this.
# PORT=7340

# Optional — override the host-side port exposed by docker compose if 7340
# collides with another local service.
# UNITY_PORT=9340

# Optional — base URL used by the integration test harness (test/integration/*).
# Default: http://localhost:7340
# UNITY_BASE_URL=http://localhost:7340
